   "source": [
    "SELECT county_state_name,\n",
    "       population,\n",
    "       CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE) / CAST(population AS DOUBLE) AS emissions_per_person\n",
    "FROM emissions_data\n",
    "ORDER BY emissions_per_person DESC\n",
    "LIMIT 10"
