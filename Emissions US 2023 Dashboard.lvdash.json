{
  "datasets": [
    {
      "name": "a8abca66",
      "displayName": "Location Data",
      "queryLines": [
        "SELECT latitude,\r\n",
        "longitude,\r\n",
        "`GHG emissions mtons CO2e` as Emissions\r\n",
        " FROM emissions_data"
      ],
      "catalog": "emission",
      "schema": "default"
    },
    {
      "name": "e4c47c5e",
      "displayName": "Emissions per Person",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE) / CAST(population AS DOUBLE) AS emissions_per_person\r\n",
        "FROM emissions_data\r\n",
        "ORDER BY emissions_per_person DESC\r\n",
        "--LIMIT 10"
      ],
      "catalog": "emission",
      "schema": "default"
    },
    {
      "name": "3fbc9438",
      "displayName": "Total Emissions per State",
      "queryLines": [
        "SELECT state_abbr,\r\n",
        "       SUM(CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE)) as total_emissions\r\n",
        "FROM emissions_data\r\n",
        "GROUP BY state_abbr\r\n",
        "ORDER BY total_emissions DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "emission",
      "schema": "default"
    },
    {
      "name": "e99d3a8e",
      "displayName": "Total Emissions per County",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(REPLACE(`GHG emissions mtons CO2e`, ',', '') AS DOUBLE) AS total_emissions\r\n",
        "FROM emissions_data\r\n",
        "ORDER BY total_emissions DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "emission",
      "schema": "default"
    }
  ],
